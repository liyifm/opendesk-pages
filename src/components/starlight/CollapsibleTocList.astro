---
interface TocItem {
  slug: string;
  text: string;
  children: TocItem[];
}

interface Props {
  toc: TocItem[];
  depth?: number;
}

const { toc, depth = 0 } = Astro.props;
---

<ul class="opendesk-toc-list" data-depth={depth}>
  {
    toc.map((heading) => {
      const href = `#${heading.slug}`;

      return (
        <li class="opendesk-toc-item">
          {
            heading.children.length > 0 ? (
              <details class="opendesk-toc-branch" data-slug={heading.slug} open={depth === 0}>
                <summary>
                  <span class="opendesk-toc-caret" aria-hidden="true"></span>
                  <span class="opendesk-toc-branch-label">{heading.text}</span>
                </summary>
                <Astro.self toc={heading.children} depth={depth + 1} />
              </details>
            ) : (
              <a class="opendesk-toc-leaf" href={href}>
                <span>{heading.text}</span>
              </a>
            )
          }
        </li>
      );
    })
  }
</ul>
